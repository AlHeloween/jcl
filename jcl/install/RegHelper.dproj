<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{B1C2D3E4-F5A6-7890-ABCD-EF1234567891}</ProjectGuid>
        <MainSource>RegHelper.dpr</MainSource>
        <ProjectVersion>37.0</ProjectVersion>
        <Config Condition="'$(Config)'==''">Release</Config>
        <DCC_DCCCompiler>DCC32</DCC_DCCCompiler>
        <AppType>Application</AppType>
        <FrameworkType>None</FrameworkType>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <TargetedPlatforms>1</TargetedPlatforms>
        <Base>true</Base>
        <DCC_ConsoleTarget>true</DCC_ConsoleTarget>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_Namespace>System;System.Win;Winapi;Vcl;$(DCC_Namespace)</DCC_Namespace>
        <DCC_DebugInformation>0</DCC_DebugInformation>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <VerInfo_Locale>1033</VerInfo_Locale>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2_Win32)'!='' or '$(Config)'=='Release'">
        <Cfg_2>true</Cfg_2>
        <Cfg_2_Win32>true</Cfg_2_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
        <DCC_DcuOutput>..\..\lib\d37\win32</DCC_DcuOutput>
        <DCC_UnitSearchPath>..\..\lib\d37\win32;..\source\include;..\source\common;..\source\windows;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\source\common\JclAnsiStrings.pas"/>
        <DCCReference Include="..\source\common\JclHelpUtils.pas"/>
        <DCCReference Include="..\source\common\JclSysUtils.pas"/>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Application</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality/>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">False</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')" Project="$(BDS)\Bin\CodeGear.Delphi.Targets"/>
</Project>
