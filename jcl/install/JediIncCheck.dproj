<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{C1D2E3F4-A5B6-7890-CDEF-123456789012}</ProjectGuid>
        <MainSource>JediIncCheck.dpr</MainSource>
        <ProjectVersion>37.0</ProjectVersion>
        <Config Condition="'$(Config)'==''">Release</Config>
        <DCC_DCCCompiler>DCC32</DCC_DCCCompiler>
        <AppType>Application</AppType>
        <FrameworkType>None</FrameworkType>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <TargetedPlatforms>1</TargetedPlatforms>
        <Base>true</Base>
        <DCC_ConsoleTarget>true</DCC_ConsoleTarget>
        <DCC_OutputDir>..\bin</DCC_OutputDir>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''"> 
        <DCC_Namespace>System;System.Win;Winapi;$(DCC_Namespace)</DCC_Namespace>
        <DCC_DebugInformation>0</DCC_DebugInformation>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <BuildConfiguration Include="Release">
            <Key>Release</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Application</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality/>
            <Platforms><Platform value="Win32">True</Platform><Platform value="Win64">False</Platform></Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')" Project="$(BDS)\Bin\CodeGear.Delphi.Targets"/>
</Project>
