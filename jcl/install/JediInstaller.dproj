<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{3A9A06EC-AE74-425F-B057-7BF3B87D937A}</ProjectGuid>
        <MainSource>JediInstaller.dpr</MainSource>
        <ProjectVersion>37.0</ProjectVersion>
        <Config Condition="'$(Config)'==''">Release</Config>
        <DCC_DCCCompiler>DCC32</DCC_DCCCompiler>
        <AppType>Application</AppType>
        <FrameworkType>VCL</FrameworkType>
        <Base>True</Base>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <TargetedPlatforms>1</TargetedPlatforms>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win32)'!=''">
        <Cfg_1_Win32>true</Cfg_1_Win32>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win32)'!=''">
        <Cfg_2_Win32>true</Cfg_2_Win32>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>JediInstaller</SanitizedProjectName>
        <DCC_Namespace>System;System.Win;Vcl;Vcl.Imaging;Winapi;Xml;Data;$(DCC_Namespace)</DCC_Namespace>
        <DCC_ConsoleTarget>true</DCC_ConsoleTarget>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <VerInfo_Locale>1033</VerInfo_Locale>
        <VerInfo_Keys>CompanyName=Project JEDI;FileDescription=JEDI installer;FileVersion=2.1.0.0;InternalName=JediInstaller;LegalCopyright=Copyright (C) 1999, 2025 Project JEDI;OriginalFilename=JediInstaller.exe;ProductName=JEDI Installer;ProductVersion=2.1</VerInfo_Keys>
        <DCC_Define>JCLINSTALL;$(DCC_Define)</DCC_Define>
        <DCC_OutputDir>..\bin</DCC_OutputDir>
        <DCC_UnitSearchPath>$(BDS)\lib\Win32\release;..\source\include;..\source\common;..\source\windows;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <DCC_DebugInformation>0</DCC_DebugInformation>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2_Win32)'!=''">
        <DCC_DcuOutput>..\lib\d37\win32</DCC_DcuOutput>
        <DCC_ObjOutput>..\lib\d37\win32</DCC_ObjOutput>
        <DCC_UnitSearchPath>$(BDS)\lib\Win32\release;..\lib\d37\win32;..\source\include;..\source\common;..\source\windows;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="JclInstall.pas"/>
        <DCCReference Include="JediInstall.pas"/>
        <DCCReference Include="JediInstallConfigIni.pas"/>
        <DCCReference Include="..\source\common\JclIDEUtils.pas"/>
        <DCCReference Include="..\source\common\JclResources.pas"/>
        <DCCReference Include="JediRegInfo.pas"/>
        <DCCReference Include="VclGui\FrmCompile.pas">
            <Form>FormCompile</Form>
        </DCCReference>
        <DCCReference Include="VclGui\JediGUIText.pas">
            <Form>TextFrame</Form>
            <DesignClass>TFrame</DesignClass>
        </DCCReference>
        <DCCReference Include="VclGui\JediGUIInstall.pas">
            <Form>InstallFrame</Form>
            <DesignClass>TFrame</DesignClass>
        </DCCReference>
        <DCCReference Include="VclGui\JediGUIMain.pas">
            <Form>MainForm</Form>
        </DCCReference>
        <DCCReference Include="VclGui\JediGUIProfiles.pas">
            <Form>ProfilesFrame</Form>
            <DesignClass>TFrame</DesignClass>
        </DCCReference>
        <DCCReference Include="JediProfiles.pas"/>
        <DCCReference Include="JclInstallResources.pas"/>
        <DCCReference Include="JediInstallResources.pas"/>
        <DCCReference Include="..\source\windows\JclMsBuild.pas"/>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>VCLApplication</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">JediInstaller.dpr</Source>
                </Source>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">False</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')" Project="$(BDS)\Bin\CodeGear.Delphi.Targets"/>
    <Import Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')" Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj"/>
    <Import Project="$(MSBuildProjectName).deployproj" Condition="Exists('$(MSBuildProjectName).deployproj')"/>
</Project>
