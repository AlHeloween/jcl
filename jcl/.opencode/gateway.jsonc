// AUTO-GENERATED by opencode - user edits below this line will be preserved
//
// Gateway Configuration (JSONC - comments are supported)
// This file controls the opencode gateway (HTTP proxy for LLM requests).
//
// API keys and OAuth tokens are NOT stored here. They are managed via
// opencode's auth system (~/.local/share/opencode/auth.json).
//
// GLOBAL GATEWAY SETTINGS
// -----------------------
// gateway.enabled: Enable or disable the gateway. Default: true.
// gateway.debug: Enable debug mode for gateway internals. Default: false.
// gateway.logging.enabled: Enable gateway request logging. Default: false.
// gateway.logging.format: Log format - "json" or "text". Default: "json".
// gateway.logging.logBodies: Include request/response bodies in logs. Default: false.
// gateway.logging.maxBodySize: Max body size in bytes to include in logs. Default: 10000.
//
// PROVIDER SETTINGS
// -----------------
// Each provider in "providers" has these settings:
// providers.<name>.name: Human-readable provider name.
// providers.<name>.env: Environment variable names required for this provider
//   (e.g. ["OPENAI_API_KEY"]). Values are read from auth system, not this file.
// providers.<name>.api: API base URL for the provider.
// providers.<name>.npm: NPM package for the provider SDK
//   (e.g. "@ai-sdk/openai-compatible", "@ai-sdk/anthropic").
// providers.<name>.options.timeout: Total request timeout in milliseconds.
//   Default: 1800000 (30 minutes).
// providers.<name>.options.chunkTimeout: Idle timeout between streaming chunks
//   in milliseconds. Default: 600000 (10 minutes).
//
// MODEL SETTINGS
// --------------
// Each model under a provider can override settings:
// providers.<name>.models.<model>.gateway.enabled: Override gateway enabled for this model.
// providers.<name>.models.<model>.gateway.debug: Enable debug mode for this model.
// providers.<name>.models.<model>.gateway.logging.*: Override logging settings for this model.
// providers.<name>.models.<model>.provider.api: Override API URL for this model.
// providers.<name>.models.<model>.provider.npm: Override NPM package for this model.
// providers.<name>.models.<model>.limit.context: Context window size in tokens.
// providers.<name>.models.<model>.limit.output: Maximum output tokens.
// providers.<name>.models.<model>.metadata.*: Model metadata (cost, capabilities, etc.).
//

{
  "$schema": "https://opencode.ai/config.json",
  "providers": {},
  "gateway": {
    "enabled": true,
    "logging": {
      "enabled": false,
      "format": "json"
    }
  }
}
